# Trecho para o ~/.profile - pyenv apenas no login (o "init - bash" completo
# fica no ~/.bashrc, no bloco interativo). Sintaxe POSIX: o ~/.profile pode ser
# lido por /bin/sh, entao nada de [[ ]] ou outras construcoes so'-bash aqui.

export PYENV_ROOT="$HOME/.pyenv"
if [ -d "$PYENV_ROOT/bin" ]; then
  case ":$PATH:" in
    *":$PYENV_ROOT/bin:"*) ;;
    *) PATH="$PYENV_ROOT/bin:$PATH" ;;
  esac
  export PATH
fi
command -v pyenv >/dev/null 2>&1 && eval "$(pyenv init --path)"
